# Binance read-only sync configuration.
# Copy this file to .env on the Linux server and fill in your read-only key.

BINANCE_API_KEY=replace_with_read_only_api_key
BINANCE_API_SECRET=replace_with_read_only_api_secret

# USD-M Futures symbols to sync.
BINANCE_MARKETS=BTCUSDT,ETHUSDT,SOLUSDT

# Binance futures userTrades can be queried in chunks. Keep this modest for speed.
BINANCE_SYNC_DAYS=30

# Used only when the API balance endpoint is unavailable.
OPENCLAW_INITIAL_BALANCE=0

# If set to 1, permission-check failure stops the sync.
# Risky permissions detected by Binance always stop the sync.
BINANCE_STRICT_PERMISSION_CHECK=0
